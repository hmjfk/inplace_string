/*
basic_inplace_string<charT>型は、inplace_vector<T>型の記憶域戦略に基づくbasic_string<charT>型である。
それ以外は、basic_string<charT>と同じ機能をもつ。
*/
template <typename charT, typename traits = char_traits<charT>, size_t N = 0>
struct basic_inplace_string
{
  private:
    template <typename CharT>
    using implementation_defined = std::string_view<CharT>::const_iterator;

  public:
    // types
    using traits_type = traits;
    using value_type = charT;
    using pointer = value_type*;
    using const_pointer = const value_type*;
    using reference = value_type&;
    using const_reference = const value_type&;
    using const_iterator = implementation_defined<charT>; // see [string.inplace.iterators]
    using iterator = implementation_defined<charT>;       // see [string.inplace.iterators]
    using const_reverse_iterator = std::reverse_iterator<const_iterator>;
    using reverse_iterator = std::reverse_iterator<iterator>;
    using size_type = size_t;
    using difference_type = ptrdiff_t;
    static constexpr size_type npos = size_type(-1);

    // [string.inplace.cons], construction and assignment
    constexpr basic_inplace_string() noexcept;
    constexpr basic_inplace_string(const basic_inplace_string&) noexcept = default;
    constexpr basic_inplace_string& operator=(const basic_inplace_string&) noexcept = default;
    constexpr basic_inplace_string(const charT* str);
    basic_inplace_string(nullptr_t) = delete;
    constexpr basic_inplace_string(const charT* str, size_type len);
    template <class It, class End>
    constexpr basic_inplace_string(It begin, End end);
    template <class R>
    constexpr explicit basic_inplace_string(R&& r);

    // [string.iterators], iterators
    constexpr iterator begin() noexcept
    { return iterator(data()); }
    constexpr const_iterator begin() const noexcept
    { return const_iterator(data()); }
    constexpr iterator end() noexcept
    { return iterator(data() + len); }
    constexpr const_iterator end() const noexcept
    { return const_iterator(data() + len); }
    constexpr reverse_iterator rbegin() noexcept
    { return reverse_iterator(end()); }
    constexpr const_reverse_iterator rbegin() const noexcept
    { return const_reverse_iterator(end()); }
    constexpr reverse_iterator rend() noexcept
    { return reverse_iterator(begin()); }
    constexpr const_reverse_iterator rend() const noexcept
    { return const_reverse_iterator(begin()); }

    constexpr const_iterator cbegin() const noexcept { return begin(); }
    constexpr const_iterator cend() const noexcept { return end(); }
    constexpr const_reverse_iterator crbegin() const noexcept { return rbegin(); }
    constexpr const_reverse_iterator crend() const noexcept { return rend(); }

    // [string.inplace.capacity], capacity
    constexpr size_type size() const noexcept
    {
        if (len > N)
          unreachable();
        else
          return len;
    }
    constexpr size_type length() const noexcept{ return size(); }
    constexpr size_type max_size() const noexcept { return N; }
#if __STDC_HOSTED__
    constexpr void resize(size_type sz); // freestanding-deleted
    constexpr void resize(size_type sz,
                          const charT& c); // freestanding-deleted
#endif
    constexpr size_type capacity() const noexcept { return N; }
    constexpr void reserve(size_type res_arg){}
    constexpr void shrink_to_fit(){}
    constexpr bool empty() const noexcept { return len == 0; }
    // [string.inplace.access], element access
    constexpr const_reference operator[](size_type pos) const { return str[pos]; }
    constexpr reference operator[](size_type pos) { return str[pos]; }
#if __STDC_HOSTED__
    constexpr const_reference at(size_type n) const; // freestanding-deleted
    constexpr reference at(size_type n);             // freestanding-deleted
#endif

    constexpr const_reference front() const;
    constexpr reference front();
    constexpr const_reference back() const;
    constexpr reference back();

    // [string.inplace.modifiers], modifiers
    constexpr std::optional<reference> operator+=(const basic_inplace_string& str);
    template <class T>
    constexpr std::optional<reference> operator+=(const T& t);
    constexpr std::optional<reference> operator+=(const charT* s);
    constexpr std::optional<reference> operator+=(charT c);
    constexpr std::optional<reference> operator+=(initializer_list<charT>);
#if __STDC_HOSTED__
    constexpr std::optional<reference> append(const basic_inplace_string& str);                                    // freestanding-deleted
    constexpr std::optional<reference> append(const basic_inplace_string& str, size_type pos, size_type n = npos); // freestanding-deleted
    template <class T>
    constexpr basic_inplace_string& append(const T& t); // freestanding-deleted
    template <class T>
    constexpr basic_inplace_string& append(const T& t, size_type pos, size_type n = npos); // freestanding-deleted
    constexpr basic_inplace_string& append(const charT* s, size_type n);                   // freestanding-deleted
    constexpr basic_inplace_string& append(const charT* s);                                // freestanding-deleted
    constexpr basic_inplace_string& append(const charT* s, size_type pos, size_type n);    // freestanding-deleted
    constexpr basic_inplace_string& append(size_type n, charT c);                          // freestanding-deleted
    template <class InputIterator>
    constexpr basic_inplace_string& append(InputIterator first, InputIterator last); // freestanding-deleted
    template <container_compatible_range<charT> R>
    constexpr basic_inplace_string& append_range(R&& rg);            // freestanding-deleted
    constexpr basic_inplace_string& append(initializer_list<charT>); // freestanding-deleted
#endif

    template <class... Args>
    constexpr optional<reference> try_emplace_back(Args&&... args);
    constexpr optional<reference> try_push_back(charT x);

    template <class... Args>
    constexpr reference unchecked_emplace_back(Args&&... args);
    constexpr reference unchecked_push_back(const T& x);
    constexpr reference unchecked_push_back(T&& x);

    constexpr void remove_prefix(size_type n);
    constexpr void remove_suffix(size_type n);
    constexpr void swap(basic_inplace_string& s) noexcept;
    constexpr void clear() noexcept;

    // [string.inplace.ops], string operations
    constexpr const charT* c_str() const noexcept;
    constexpr const charT* data() const noexcept;
    constexpr charT* data() noexcept;
    constexpr operator basic_string_view<charT, traits>() const noexcept;

#if __STDC_HOSTED__
    constexpr size_type copy(charT* s, size_type n,
                             size_type pos = 0) const; // freestanding-deleted

    constexpr basic_inplace_string substr(size_type pos = 0,
                                          size_type n = npos) const; // freestanding-deleted
    constexpr basic_inplace_string subview(size_type pos = 0,
                                           size_type n = npos) const; // freestanding-deleted

    constexpr int compare(basic_inplace_string s) const noexcept;
    constexpr int compare(size_type pos1, size_type n1,
                          basic_inplace_string s) const; // freestanding-deleted
    constexpr int compare(size_type pos1, size_type n1, basic_inplace_string s, size_type pos2,
                          size_type n2) const; // freestanding-deleted
    constexpr int compare(const charT* s) const;
    constexpr int compare(size_type pos1, size_type n1,
                          const charT* s) const; // freestanding-deleted
    constexpr int compare(size_type pos1, size_type n1, const charT* s,
                          size_type n2) const; // freestanding-deleted
#endif
    constexpr bool starts_with(basic_inplace_string x) const noexcept;
    constexpr bool starts_with(charT x) const noexcept;
    constexpr bool starts_with(const charT* x) const;
    constexpr bool ends_with(basic_inplace_string x) const noexcept;
    constexpr bool ends_with(charT x) const noexcept;
    constexpr bool ends_with(const charT* x) const;

    constexpr bool contains(basic_inplace_string x) const noexcept;
    constexpr bool contains(charT x) const noexcept;
    constexpr bool contains(const charT* x) const;

    // [string.inplace.find], searching
    constexpr size_type find(basic_inplace_string s, size_type pos = 0) const noexcept;
    constexpr size_type find(charT c, size_type pos = 0) const noexcept;
    constexpr size_type find(const charT* s, size_type pos, size_type n) const;
    constexpr size_type find(const charT* s, size_type pos = 0) const;
    constexpr size_type rfind(basic_inplace_string s, size_type pos = npos) const noexcept;
    constexpr size_type rfind(charT c, size_type pos = npos) const noexcept;
    constexpr size_type rfind(const charT* s, size_type pos, size_type n) const;
    constexpr size_type rfind(const charT* s, size_type pos = npos) const;

    constexpr size_type find_first_of(basic_inplace_string s, size_type pos = 0) const noexcept;
    constexpr size_type find_first_of(charT c, size_type pos = 0) const noexcept;
    constexpr size_type find_first_of(const charT* s, size_type pos, size_type n) const;
    constexpr size_type find_first_of(const charT* s, size_type pos = 0) const;
    constexpr size_type find_last_of(basic_inplace_string s, size_type pos = npos) const noexcept;
    constexpr size_type find_last_of(charT c, size_type pos = npos) const noexcept;
    constexpr size_type find_last_of(const charT* s, size_type pos, size_type n) const;
    constexpr size_type find_last_of(const charT* s, size_type pos = npos) const;
    constexpr size_type find_first_not_of(basic_inplace_string s, size_type pos = 0) const noexcept;
    constexpr size_type find_first_not_of(charT c, size_type pos = 0) const noexcept;
    constexpr size_type find_first_not_of(const charT* s, size_type pos, size_type n) const;
    constexpr size_type find_first_not_of(const charT* s, size_type pos = 0) const;
    constexpr size_type find_last_not_of(basic_inplace_string s, size_type pos = npos) const noexcept;
    constexpr size_type find_last_not_of(charT c, size_type pos = npos) const noexcept;
    constexpr size_type find_last_not_of(const charT* s, size_type pos, size_type n) const;
    constexpr size_type find_last_not_of(const charT* s, size_type pos = npos) const;

  // exposition only
  private:
    charT str[N];
    size_type len;
};

// basic_string_view typedef-names
using inplace_string = basic_inplacce_string<char>;
using inplace_u8string = basic_inplacce_string<char8_t>;
using inplace_u16string = basic_inplacce_string<char16_t>;
using inplace_u32string = basic_inplacce_string<char32_t>;
using inplace_wstring = basic_inplacce_string<wchar_t>;

// [string.view.hash], hash support
template <class T>
struct hash;

template <>
struct hash<inplace_string>;
template <>
struct hash<inplace_u8string>;
template <>
struct hash<inplace_u16string>;
template <>
struct hash<inplace_u32string>;
template <>
struct hash<inplace_wstring>;

// clang-format off
inline namespace literals::inline string_literals
{
    // [basic.inplace.literals], suffix for basic_inplace_string literals
    static inline constexpr inplace_string operator""si(const char* str, size_t len){ return inplace_string{str, len}; }
    static inline constexpr inplace_u8string operator""si(const char8_t* str, size_t len){ return inplace_u8string{str, len}; }
    static inline constexpr inplace_u16string operator""si(const char16_t* str, size_t len){ return inplace_u16string{str, len}; }
    static inline constexpr inplace_u32string operator""si(const char32_t* str, size_t len){ return inplace_u32string{str, len}; }
    static inline constexpr inplace_wstring operator""si(const wchar_t* str, size_t len){ return inplace_wstring{str, len}; }
} // namespace literals::string_literals
} // namespace std::experimental

